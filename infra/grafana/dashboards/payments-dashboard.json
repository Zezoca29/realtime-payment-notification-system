{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Realtime Payment Notification System — Service Observability",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP — Payment Producer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]},
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Request Rate (payment-producer)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "rate(http_server_requests_seconds_count{application=\"payment-producer\"}[1m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]},
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Error Rate (payment-producer)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "rate(http_server_requests_seconds_count{application=\"payment-producer\",status=~\"5..\"}[1m]) / rate(http_server_requests_seconds_count{application=\"payment-producer\"}[1m])",
        "legendFormat": "error rate"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "red", "value": 0.5 }
          ]},
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "P99 Latency (payment-producer)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"payment-producer\", uri=\"/api/v1/payments\"}[5m]))",
        "legendFormat": "p99"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "title": "Pending Outbox Events",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "payment_outbox_pending_total{application=\"payment-producer\"}",
        "legendFormat": "pending"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HTTP Request Rate by Status (payment-producer)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "rate(http_server_requests_seconds_count{application=\"payment-producer\"}[1m])",
        "legendFormat": "{{status}} {{uri}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Latency Percentiles (payment-producer)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{application=\"payment-producer\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"payment-producer\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"payment-producer\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 200,
      "title": "Kafka Consumer — Notification Consumer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Kafka Consumer Lag (notification-consumer)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "kafka_consumer_fetch_manager_records_lag{application=\"notification-consumer\"}",
        "legendFormat": "lag {{topic}} p{{partition}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Circuit Breaker State (websocket-gateway calls)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "resilience4j_circuitbreaker_state{application=\"notification-consumer\"}",
        "legendFormat": "{{name}} — {{state}}"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 300,
      "title": "JVM — All Services",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "jvm_memory_used_bytes{area=\"heap\"}",
        "legendFormat": "{{application}} — {{id}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "JVM CPU Usage",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "process_cpu_usage",
        "legendFormat": "{{application}}"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["payments", "kafka", "spring-boot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Payment Notification System",
  "uid": "payment-system-v1",
  "version": 1
}
